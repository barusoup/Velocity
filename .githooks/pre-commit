#!/usr/bin/env node
// .githooks/pre-commit
//
// Opt-in client-side guardrail. Wire once:
//   git config core.hooksPath .githooks
//   chmod +x .githooks/pre-commit          # macOS only
//
// The hook mirrors the same icon-system regression checks as
// scripts/verify-release-assets.mjs but blocks them BEFORE git writes
// the commit object, so a bad state can't even land in the source branch.
// To skip for a single commit (urgent hotfix), `git commit --no-verify`.

import { execSync } from "node:child_process";
import { readFileSync, existsSync } from "node:fs";

function fail(msg) {
  console.error(`\u274C pre-commit: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.log(`  pre-commit: ${msg}`);
}

let blocked = false;

// 1. Bundle.icon re-adds 'icons/desktop-icon.png' (the wrapper).
//
// Read the WORKING TREE, not git-staged bytes. pre-commit runs AFTER
// the user's edits but BEFORE `git add`. A developer who edits
// tauri.conf.json to reintroduce desktop-icon.png and then commits
// without `git add` would have the staged version still be the
// previously-committed (good) one — `git show :src-tauri/tauri.conf.json`
// wouldn't see the regression. The working tree IS what git will write
// once they add+commit, so it is the correct source for the gate.
const confPath = "src-tauri/tauri.conf.json";
if (existsSync(confPath)) {
  try {
    const workingTree = readFileSync(confPath, "utf8");
    if (workingTree.includes('"icons/desktop-icon.png"')) {
      fail(
        `tauri.conf.json bundle.icon re-adds 'icons/desktop-icon.png'. ` +
          `The 875x875 wrapper is the SOURCE for 'npx tauri icon', not a ` +
          `bundling target. Remove it from bundle.icon before committing.`,
      );
      blocked = true;
    }
  } catch {
    /* ignore read errors */
  }
}
if (!blocked) info("bundle.icon does not contain 'desktop-icon.png'");

// 2. public/icon.png or splash-icon.png staged for deletion.
try {
  const deleted = execSync(
    `git diff --cached --diff-filter=D --name-only -- public/icon.png public/splash-icon.png`,
    { encoding: "utf8" },
  );
  const lines = deleted.split("\n").filter(Boolean);
  if (lines.length > 0) {
    fail(
      `cannot delete ${lines.join(", ")}: required at runtime (sidebar brand + ` +
        `splash image + DefaultArtwork). Replace the bytes instead of ` +
        `git rm'ing.`,
    );
    blocked = true;
  }
} catch {
  // git returns 1 if no matches — treat as "OK, no deletions".
}
if (!blocked) info("public/icon.png + public/splash-icon.png are not staged for deletion");

// 3. icon.ico multi-frame regression (working-tree bytes — same reasoning
// as check #1: pre-commit runs before `git add`, so the staged copy
// still reflects the previously-committed version).
const icoPath = "src-tauri/icons/icon.ico";
if (existsSync(icoPath)) {
  try {
    const buf = readFileSync(icoPath);
    if (buf.length < 6) {
      fail(`icon.ico is too small (${buf.length} bytes) to be a valid ICO`);
      blocked = true;
      } else {
        const count = buf[4] | (buf[5] << 8);
        if (count < 3) {
          fail(
            `icon.ico has only ${count} frame(s). Windows taskbar will be ` +
              `blurry. Re-run 'npm run regen-icons'.`,
          );
          blocked = true;
        } else {
          let largestFirst = true;
          let prevArea = Infinity;
          for (let i = 0; i < count; i++) {
            const off = 6 + i * 16;
            const w = buf[off];
            const h = buf[off + 1];
            const fw = w === 0 ? 256 : w;
            const fh = h === 0 ? 256 : h;
            const area = fw * fh;
            if (area > prevArea) largestFirst = false;
            prevArea = area;
          }
          if (!largestFirst) {
            fail(
              `icon.ico frames are not ordered largest-first. Windows ` +
                `desktop-shortcut rendering paths may upscale a small frame. ` +
                `Re-run 'npm run regen-icons'.`,
            );
            blocked = true;
          } else {
            info(`icon.ico has ${count} frames, largest-first`);
          }
        }
      }
  } catch {
    /* ignore read errors */
  }
}

if (!blocked) info("all icon-system checks passed");
process.exit(0);
