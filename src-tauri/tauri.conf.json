{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity",
  "version": "0.0.1",
  "identifier": "com.velocity.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Velocity",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": [0, 0, 0, 255],
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCMEE3MThDQjZBMkQyRDMKUldUVDBxSzJqSEVLMnphcXZUMlVLSjhuelZucnNCRHZ6dmxuMXM1NTVZdis3dHVRemc0RXYzem4K",
      "endpoints": [
        "https://github.com/barusoup/Velocity-Public/releases/latest/download/latest.json"
      ]
    }
  }
}
